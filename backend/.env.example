# Copy to .env and fill in real values (never commit .env)

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/joblens?retryWrites=true&w=majority
JWT_SECRET=use_a_long_random_string_in_production
PORT=5000

# Production: set to your deployed frontend origin (no trailing slash), e.g. https://myapp.vercel.app
# Development: optional; localhost / 127.0.0.1 on any port is always allowed when NODE_ENV is not production
FRONTEND_URL=
